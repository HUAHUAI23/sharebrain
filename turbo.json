{
  "$schema": "./node_modules/turbo/schema.json",
  "globalDependencies": [
    "messages/**",
    "project.inlang/**"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "NODE_ENV",
    "DEV_AUTH_USER_ID",
    "DEV_AUTH_TENANT_ID",
    "DEV_AUTH_ROLE",
    "AUTH_PASSWORD_REGISTRATION_ENABLED",
    "AUTH_DEV_BYPASS_ENABLED",
    "AUTH_SESSION_COOKIE_NAME",
    "AUTH_SESSION_EXPIRES_DAYS",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET",
    "S3_FORCE_PATH_STYLE",
    "MEDIA_UPLOAD_MAX_BYTES",
    "MEDIA_UPLOAD_EXPIRES_SECONDS",
    "MEDIA_READ_URL_EXPIRES_SECONDS",
    "WEB_PUBLIC_API_BASE_URL",
    "WEB_PUBLIC_COLLAB_WS_URL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**", "src/paraglide/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
