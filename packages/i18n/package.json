{
  "name": "@sharebrain/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./paraglide/*": {
      "types": "./src/paraglide/*.d.ts",
      "default": "./src/paraglide/*.js"
    }
  },
  "scripts": {
    "paraglide:compile": "bun scripts/with-paraglide.ts compile",
    "build": "bun scripts/with-paraglide.ts build",
    "typecheck": "bun scripts/with-paraglide.ts typecheck",
    "test": "bun --eval \"console.log('no i18n tests yet')\""
  },
  "dependencies": {
    "@inlang/paraglide-js": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sharebrain/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
