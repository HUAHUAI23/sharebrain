{
  "name": "@sharebrain/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "bun src/scripts/reset.ts",
    "db:reset:push": "bun run db:reset && bun run db:push",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@sharebrain/config": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "@sharebrain/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
