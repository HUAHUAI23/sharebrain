{
  "name": "@sharebrain/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/button": {
      "types": "./src/components/button.tsx",
      "default": "./src/components/button.tsx"
    },
    "./components/input": {
      "types": "./src/components/input.tsx",
      "default": "./src/components/input.tsx"
    },
    "./components/surface": {
      "types": "./src/components/surface.tsx",
      "default": "./src/components/surface.tsx"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "devDependencies": {
    "@sharebrain/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
