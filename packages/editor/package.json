    "@platejs/code-block": "catalog:",
    "@platejs/combobox": "catalog:",
    "@platejs/comment": "catalog:",
    "@platejs/core": "catalog:",
    "@platejs/dnd": "catalog:",
    "@platejs/floating": "catalog:",
    "@platejs/indent": "catalog:",
    "@platejs/link": "catalog:",
    "@platejs/list": "catalog:",
    "@platejs/markdown": "catalog:",
    "@platejs/resizable": "catalog:",
    "@platejs/selection": "catalog:",
    "@platejs/slash-command": "catalog:",
    "@platejs/suggestion": "catalog:",
    "@platejs/table": "catalog:",
    "@platejs/toc": "catalog:",
    "@platejs/toggle": "catalog:",
    "@platejs/yjs": "catalog:",
