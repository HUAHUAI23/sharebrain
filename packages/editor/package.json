{
  "name": "@sharebrain/editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./kits/*": {
      "types": "./src/kits/*.tsx",
      "default": "./src/kits/*.tsx"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "default": "./src/ui/*.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun --eval \"console.log('no editor tests yet')\""
  },
