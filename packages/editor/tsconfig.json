{
  "extends": "@sharebrain/typescript-config/react-app",
  "compilerOptions": {
    "rootDir": "src",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
