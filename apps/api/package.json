{
  "name": "@sharebrain/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app/create-app.ts",
      "default": "./src/app/create-app.ts"
    }
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test --timeout 30000"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "ai": "catalog:",
    "@aws-sdk/s3-presigned-post": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@dicebear/core": "catalog:",
    "@dicebear/styles": "catalog:",
    "@hono/zod-openapi": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "@sharebrain/config": "workspace:*",
    "@sharebrain/contracts": "workspace:*",
    "@sharebrain/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "sharp": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sharebrain/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
