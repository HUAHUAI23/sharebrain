NODE_ENV=development
DATABASE_URL=postgres://sharebrain:sharebrain@127.0.0.1:5432/sharebrain
API_PORT=3001
COLLAB_PORT=3002
WORKER_CONCURRENCY=2
DEV_AUTH_USER_ID=00000000-0000-4000-8000-000000000001
DEV_AUTH_TENANT_ID=00000000-0000-4000-8000-000000000101
DEV_AUTH_ROLE=admin
AUTH_PASSWORD_REGISTRATION_ENABLED=true
AUTH_DEV_BYPASS_ENABLED=true
AUTH_SESSION_COOKIE_NAME=sharebrain_session
AUTH_SESSION_EXPIRES_DAYS=30
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=sharebrain-dev
S3_FORCE_PATH_STYLE=true
MEDIA_UPLOAD_MAX_BYTES=26214400
MEDIA_AVATAR_MAX_BYTES=5242880
MEDIA_UPLOAD_EXPIRES_SECONDS=600
MEDIA_READ_URL_EXPIRES_SECONDS=300
MEDIA_GC_INTERVAL_SECONDS=60
MEDIA_GC_BATCH_SIZE=50
MEDIA_GC_PROCESSING_TIMEOUT_SECONDS=300
DOCUMENT_VERSION_HISTORY_ENABLED=true
DOCUMENT_VERSION_RESTORE_ENABLED=false
DOCUMENT_VERSION_IDLE_SEAL_SECONDS=120
DOCUMENT_VERSION_IDLE_SEAL_INTERVAL_SECONDS=30
DOCUMENT_VERSION_IDLE_SEAL_BATCH_SIZE=100
DOCUMENT_VERSION_RETENTION_DAYS=90
DOCUMENT_VERSION_RETENTION_INTERVAL_SECONDS=86400
DOCUMENT_VERSION_RETENTION_BATCH_SIZE=100
DOCUMENT_VERSION_RETENTION_DRY_RUN=true
DOCUMENT_VERSION_OPERATION_EXPIRES_SECONDS=600
DOCUMENT_ACTIVITY_HISTORY_ENABLED=true
DOCUMENT_ACTIVITY_IDLE_SEAL_SECONDS=120
DOCUMENT_ACTIVITY_IDLE_SEAL_INTERVAL_SECONDS=30
DOCUMENT_ACTIVITY_IDLE_SEAL_BATCH_SIZE=100
COLLAB_REPLICA_COUNT=1
COLLAB_SHARED_SYNC_ENABLED=false
WEB_PUBLIC_API_BASE_URL=
WEB_PUBLIC_COLLAB_WS_URL=
AI_MODEL_PROVIDER=openai-compatible
AI_BASE_URL=
AI_API_KEY=
